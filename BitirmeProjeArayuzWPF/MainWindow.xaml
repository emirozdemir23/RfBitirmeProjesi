<Window x:Class="ProjeWpf1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjeWpf1"
        mc:Ignorable="d"
        Title="Nextion Wireless Terminal" Height="650" Width="1000" MinHeight="600" MinWidth="900"
        FontFamily="Segoe UI">

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0B0C10" Offset="0.0" />
            <GradientStop Color="#151720" Offset="0.5" />
            <GradientStop Color="#0B0C10" Offset="1.0" />
        </LinearGradientBrush>
    </Window.Background>

    <Window.Resources>
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#1F2833"/>
            <Setter Property="Foreground" Value="#C5C6C7"/>
            <Setter Property="BorderBrush" Value="#3066FCF1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Foreground="{TemplateBinding Foreground}" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" Focusable="False" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                                <Path Grid.Column="1" Data="M0,0 L4,4 L8,0" Stroke="#66FCF1" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" Margin="10,0,30,0" VerticalAlignment="Center" HorizontalAlignment="Left" TextElement.Foreground="#C5C6C7"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="#1F2833" BorderBrush="#3066FCF1" BorderThickness="1" CornerRadius="6" MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#C5C6C7"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2B3642"/>
                                            <Setter Property="Foreground" Value="#66FCF1"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#1A66FCF1"/>
                                            <Setter Property="Foreground" Value="#66FCF1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassCard" TargetType="Border">
            <Setter Property="Background" Value="#401F2833"/>
            <Setter Property="BorderBrush" Value="#3066FCF1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.5" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NeonButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#66FCF1"/>
            <Setter Property="BorderBrush" Value="#66FCF1"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,10"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1A66FCF1"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#66FCF1" Opacity="0.6"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#66FCF1"/>
                                <Setter Property="Foreground" Value="#0B0C10"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#1F2833"/>
            <Setter Property="Foreground" Value="#C5C6C7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,10"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2B3642"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerNeonButton" TargetType="Button">
            <Setter Property="Background" Value="#1A4A0000"/>
            <Setter Property="Foreground" Value="#FF4C4C"/>
            <Setter Property="BorderBrush" Value="#FF4C4C"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,10"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33FF4C4C"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#FF4C4C" Opacity="0.6"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Margin="0,0,5,0" Padding="15,8" CornerRadius="8,8,0,0" Background="#1F2833">
                            <ContentPresenter ContentSource="Header" TextElement.Foreground="#C5C6C7" TextElement.FontWeight="SemiBold"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1A66FCF1"/>
                                <Setter Property="TextElement.Foreground" Value="#66FCF1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="10,0,10,20">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="12" Height="12" Fill="#66FCF1" Margin="0,0,10,0">
                    <Ellipse.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#66FCF1"/>
                    </Ellipse.Effect>
                </Ellipse>
                <TextBlock Text="NEXTION TELEMETRY TERMINAL" Foreground="#C5C6C7" FontSize="20" FontWeight="Black"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource GlassCard}">
                <StackPanel>
                    <TextBlock Text="DISPLAY PARAMS" Foreground="#66FCF1" FontSize="14" FontWeight="Bold" Margin="0,0,0,25"/>

                    <TextBlock Text="REFRESH RATE" Foreground="#8A8D91" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CmbLcdYenileme" Height="35" FontSize="13" Style="{StaticResource DarkComboBox}">
                        <ComboBoxItem Content="100 ms"/>
                        <ComboBoxItem Content="250 ms"/>
                        <ComboBoxItem Content="500 ms" IsSelected="True"/>
                        <ComboBoxItem Content="1000 ms"/>
                    </ComboBox>

                    <TextBlock Text="BACKLIGHT" Foreground="#8A8D91" FontSize="11" FontWeight="SemiBold" Margin="0,25,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="RdoIsikAcik" Content="ENABLED" Foreground="#C5C6C7" IsChecked="True" Margin="0,0,20,0" FontWeight="SemiBold"/>
                        <RadioButton x:Name="RdoIsikKapali" Content="DISABLED" Foreground="#C5C6C7" FontWeight="SemiBold"/>
                    </StackPanel>

                    <Border BorderBrush="#3066FCF1" BorderThickness="0,1,0,0" Margin="0,30,0,25"/>

                    <Button x:Name="BtnEkraniTemizle" Content="CLEAR DISPLAY" Style="{StaticResource DarkButton}" Margin="0,0,0,15" Click="BtnEkraniTemizle_Click"/>
                    <Button x:Name="BtnLcdOnizleme" Content="RGB565 PREVIEW" Style="{StaticResource NeonButton}" Margin="0,0,0,15" Click="BtnLcdOnizleme_Click"/>
                    <Button x:Name="BtnKapat" Content="SYSTEM SHUTDOWN" Style="{StaticResource DarkButton}" Click="BtnKapat_Click"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource GlassCard}">
                <StackPanel>
                    <TextBlock Text="LINK &amp; HARDWARE" Foreground="#66FCF1" FontSize="14" FontWeight="Bold" Margin="0,0,0,35"/>

                    <TextBlock Text="ACTIVE MODULES" Foreground="#8A8D91" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,20"/>

                    <CheckBox x:Name="ChkPanel1" Content="Module 1" Foreground="#C5C6C7" Margin="0,0,0,15"/>
                    <CheckBox x:Name="ChkPanel2" Content="Module 2" Foreground="#C5C6C7" Margin="0,0,0,15"/>
                    <CheckBox x:Name="ChkPanel3" Content="Module 3" Foreground="#C5C6C7" Margin="0,0,0,15"/>
                    <CheckBox x:Name="ChkPanel4" Content="Module 4" Foreground="#C5C6C7" Margin="0,0,0,45"/>

                    <Button x:Name="BtnInterrupt" Style="{StaticResource DangerNeonButton}" Height="55" Click="BtnInterrupt_Click">
                        <TextBlock TextAlignment="Center" LineHeight="16">
                            FORCE INTERRUPT<LineBreak/>
                            <Run Text="HALT ALL PROCESSES" FontSize="9" Foreground="#FF9999" FontWeight="SemiBold"/>
                        </TextBlock>
                    </Button>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource GlassCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="PAYLOAD TERMINAL" Foreground="#66FCF1" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>

                    <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">

                        <TabItem Header="TEXT MESSAGE">
                            <Grid Margin="0,15,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#33000000" BorderBrush="#1A66FCF1" BorderThickness="1" CornerRadius="10">
                                    <TextBox x:Name="TxtMesaj" Background="Transparent" Foreground="#66FCF1" BorderThickness="0" Padding="15" FontSize="15" FontFamily="Consolas" VerticalContentAlignment="Top" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" CaretBrush="#66FCF1"/>
                                </Border>

                                <Grid Grid.Row="1" Margin="0,25,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="1.5*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" x:Name="BtnDuzenle" Content="PARSE DATA" Style="{StaticResource DarkButton}" Height="50" Click="BtnDuzenle_Click"/>
                                    <Button Grid.Column="2" x:Name="BtnGonder" Content="TRANSMIT PAYLOAD" Style="{StaticResource NeonButton}" Height="50" Click="BtnGonder_Click"/>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <TabItem Header="IMAGE UPLOAD">
                            <Grid Margin="0,15,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Background="#33000000" BorderBrush="#1A66FCF1" BorderThickness="1" CornerRadius="10">
                                    <Grid>
                                        <Image x:Name="ImgPreview" Margin="20" Stretch="Uniform"/>
                                        <TextBlock x:Name="TxtImgPlaceholder" Text="No Image Selected" Foreground="#45A29E" VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False"/>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="1" Margin="0,25,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="1.5*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" x:Name="BtnFotoSec" Content="SELECT IMAGE" Style="{StaticResource DarkButton}" Height="50" Click="BtnFotoSec_Click"/>
                                    <Button Grid.Column="2" x:Name="BtnFotoGonder" Content="SEND TO NEXTION" Style="{StaticResource NeonButton}" Height="50" Click="BtnFotoGonder_Click"/>
                                </Grid>
                            </Grid>
                        </TabItem>

                    </TabControl>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>